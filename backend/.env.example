# Copy to .env and adjust. After changing MSSQL_SA_PASSWORD, reset the database volume:
#   docker compose down -v
#   docker compose up --build -d
#
# Password must include upper, lower, digit, and symbol (e.g. Ris_2026! not RIS_2026).
MSSQL_SA_PASSWORD=RIS_2026
JWT_SECRET_KEY=SmartInventorySystem_DockerSecretKey_Min32Chars!
