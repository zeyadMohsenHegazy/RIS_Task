{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=SmartInventoryDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Cache": {
    "DefaultExpirationMinutes": 5
  },
  "Jwt": {
    "Issuer": "SmartInventorySystem",
    "Audience": "SmartInventorySystem.Client",
    "SecretKey": "SmartInventorySystem_DevelopmentSecretKey_Min32Chars!",
    "ExpirationMinutes": 120
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}